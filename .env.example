# ==========================================
# India Conflict Corridor Intelligence Pipeline by Caesura Intelligence
# Environment Configuration
# ==========================================

# === REQUIRED ===
# Get your free API key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# === OPTIONAL CONFIG ===

# Run browser in headless mode (recommended)
HEADLESS=True

# Extract full article content using Trafilatura
EXTRACT_FULL_CONTENT=True

# How often the scraper runs (in seconds). Default = 15 minutes
NEWS_POLL_INTERVAL_SECONDS=900

# Maximum age of articles to process (in days)
MAX_ARTICLE_AGE_DAYS=14

# How long to keep articles in the live JSON data lake (in days)
JSON_RETENTION_DAYS=60

# Risk scoring thresholds
MIN_RISK_SCORE=8.0
CIVIL_UNREST_SCORE=7.5
HIGH_RISK_THRESHOLD=8.0
MEDIUM_RISK_THRESHOLD=5.0

# BART zero-shot classifier settings
BART_MODEL=facebook/bart-large-mnli
BART_CONFIDENCE_THRESHOLD=0.55

# Enable/disable RSS ingestion
USE_RSS=True